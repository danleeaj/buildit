# Hackathon-only client configuration. Do not deploy a valuable OpenAI key in VITE_*.
VITE_OPENAI_API_KEY=sk-...
VITE_DISCOVERY_MODEL=gpt-5.6-luna
VITE_BUILD_MODEL=gpt-5.6-terra
VITE_BIG_MODEL=gpt-5.6-terra
VITE_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Required for authenticated project storage. Private: used only by Vercel
# Functions and local migration scripts.
DATABASE_URL=

# Required for sign-in. Public: Neon Auth endpoint for this Vite app.
VITE_NEON_AUTH_URL=

# Neon normally provisions the base URL. NEON_AUTH_JWKS_URL is an optional
# explicit override; otherwise the API uses the base URL's /jwt endpoint.
NEON_AUTH_BASE_URL=
NEON_AUTH_JWKS_URL=

# Neon Auth user ID that owns the seed project. It is never sent to visitors.
DEMO_OWNER_ID=
